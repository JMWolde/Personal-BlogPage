async function RetrievePostPage(id : string) {
const {data: post } = await supabase.from("Posts").select().eq('id', id)
const {data: comments} = await supabase.from("Comments").select().eq('post_id', id)
buildPostCard(post?.[0], comments)
}
function getButtons(PostCard) {
const RemoveBTN = document.createElement("button")
RemoveBTN.className = "PageRemoveBTN"
RemoveBTN.innerText= "Remove"
RemoveBTN.onclick = () => removeCard(PostCard);
const CommentBTN = document.createElement("button")
CommentBTN.className = "PageCommentBTN"
CommentBTN.innerText= "Comment"
CommentBTN.onclick = () => Comment(PostCard)

PostCard!.appendChild(RemoveBTN)
PostCard!.appendChild(CommentBTN)
return PostCard
}
function Comment(PostCard) {
const CommentBox = document.createElement("textarea")
const SubmitBTN = document.createElement("button")
SubmitBTN.id = "PageSubmitBTN"
SubmitBTN.innerText= "Submit"
SubmitBTN.onclick = () => SaveComment(PostCard, CommentBox)
CommentBox.className = "PageCard"
CommentBox.placeholder = "Type Here"
PostCard!.appendChild(CommentBox)
PostCard!.appendChild(SubmitBTN)
}
async function fetchComments(PostCard) {
const { data: comment, error: fetchError } = await supabase
.from("Comments")
.select()
.order("created_at" , {ascending: false})
.limit(1)
buildCommentCard(PostCard, comment?.[0])
}
async function SaveComment(PostCard, CommentBox) {
const PostID = PostCard.querySelector("h2").innerText.trim()
alert("Comment Posted!")
const { data, error } = await supabase.from("Comments").insert({ comment_text: CommentBox.value, post_id: PostID }) // saving comment
fetchComments(PostCard)
}

async function removeCard(PostCard) {
const key = process.env.NEXT_PUBLIC_MY_SECRET_KEY
const PostCon = document.getElementById("PageContainer")
const PostID = PostCard.querySelector("h2")
const value = window.prompt("Enter Master Key To Remove")
if (value == key) {
PostCon!.removeChild(PostCard)
await supabase.from("Posts").delete().eq('id', PostID.innerText)
} else {
alert("NAH NAH")
}
}
function ParseDate(item){
const Date = item.created_at;
const DateYear = Date.split("T")[0]; // day of year
const DateTime = Date.split("T")[1];
const DateTimeClean = DateTime.split(".")[0];
const FinalDateTime = dayjs( DateTimeClean, "HH:mm:ss").format("h:mm A") // 24 -> 12
return `${DateYear} ${FinalDateTime}`
}
function buildCommentCard(PostCard, comment){
const commentCard = document.createElement("div")
const commentText = document.createElement("p")
const ProfileName = document.createElement("h1")
const DateText = document.createElement("h4")
const commentID = document.createElement("h2")
commentID.innerText= comment.id
DateText.innerText= ParseDate(comment)
ProfileName.innerText= "Comment"
commentCard.className = "CommentCard"
commentText.innerText= comment.comment_text
commentCard!.appendChild(commentText)
commentCard!.prepend(ProfileName)
commentCard!.appendChild(commentID)
commentCard!.appendChild(DateText)
PostCard!.appendChild(commentCard)
}
async function buildPostCard(Post, comments){
if(Post.Images || Post.Post_Text) {
const PostCon = document.getElementById("PageContainer")
const PostCard = document.createElement("div")
const ProfileName = document.createElement("h1")
const DateText = document.createElement("h4")
const PostID = document.createElement("h2")


PostID.innerText = Post.id;
DateText.innerText = await ParseDate(Post)
PostCard.className = "PageCard"
ProfileName.innerText = "JOSH"

if (Post.Post_Text) {
const TextDisplay = document.createElement("p") // text post
TextDisplay.innerText = Post.Post_Text
PostCard!.appendChild(TextDisplay)
}
if (Post.Images) {
const imageDisplay = document.createElement("img") // image post
imageDisplay.src = Post.Images
PostCard!.appendChild(imageDisplay)
}
PostCard!.prepend(ProfileName)
PostCard!.appendChild(PostID)
const PostCardNEW = getButtons(PostCard)
PostCardNEW!.appendChild(DateText)
const FinalPostCard = await DisplayAllComments(PostCardNEW, comments)
PostCon!.prepend(FinalPostCard)
} else {
alert("There is nothing")
}
}
